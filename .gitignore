# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env*.example

# vercel
.vercel

# supabase
supabase/.temp

# jvlink (python, JV-Dataの生データ・ライセンス上再配布不可のため)
scripts/jvlink/out/
scripts/jvlink/**/*.txt
scripts/jvlink/__pycache__/
scripts/jvlink/.venv/
scripts/jvlink/logs/
# .env.jvlink は上の `.env*` ルールで既にignore対象

# scripts配下の他のPythonバッチ (compute_recommendation_results.py等) 共通
scripts/__pycache__/

# Windowsタスクスケジューラ用のラッパー(個人PC固有の絶対パスを含むため機体ごとに作成する)
scripts/netkeiba/run_sync_recent_task.bat
scripts/netkeiba/logs/

# typescript
*.tsbuildinfo
next-env.d.ts

# SNS投稿コンテンツパック(生成物)
/sns-out/
